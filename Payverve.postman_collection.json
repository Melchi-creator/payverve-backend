							"listen": "prerequest",
							"script": {
								"exec": [
									"// Get the current date and time in ISO 8601 format\r",
									"const currentDate = new Date(2011, 5, 28).toISOString();\r",
									"\r",
									"// Extract the date and time separately\r",
									"const dateOnly = currentDate.split('T')[0];\r",
									"const timeOnly = currentDate.split('T')[1].split('.')[0];\r",
									"\r",
									"// Extract the year\r",
									"const year = dateOnly.split('-')[0];\r",
									"\r",
									"\r",
									"// Store the date and time in Postman environment variables\r",
									"pm.environment.set('currentDate', dateOnly);\r",
									"pm.environment.set('currentTime', timeOnly);\r",
									"pm.environment.set('currentYear', year);\r",
									""
								],
								"type": "text/javascript",
